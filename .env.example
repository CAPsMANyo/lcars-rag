# Secrets and infrastructure settings ONLY.
# Tunable settings (embedding, chunking, etc.) live in config.yml.

# --- Database credentials (used by both the app and docker-compose) ---
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=your-postgres-db

# Full connection URL used by the app. When using the bundled docker-compose,
# this should match the POSTGRES_* values above.
COCOINDEX_DATABASE_URL=postgresql://your-postgres-user:your-postgres-password@localhost:5432/your-postgres-db

# --- Qdrant (comment out or leave blank to use pgvector instead) ---
QDRANT_URL=http://localhost:6334
QDRANT_API_KEY=your-qdrant-api-key
# Collection name used by the MCP server subprocess when searching Qdrant.
# Must match the collection cocoindex writes to.
QDRANT_COLLECTION=cocoindex

# --- Embedding (also read by the MCP server subprocess) ---
EMBEDDING_API_ADDRESS=http://localhost:11434/v1
EMBEDDING_MODEL=hf.co/jinaai/jina-code-embeddings-1.5b-GGUF:BF16
EMBEDDING_DIMENSION=1024

# --- Data ---
BASE_DIR=./data

# --- Source metadata (also read by the MCP server subprocess) ---
METADATA_TABLE=source_metadata

# --- Git (required only for HTTPS repositories) ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- MCP Server subprocess (lcars-mcp-server) ---
# The MCP server subprocess reuses QDRANT_*, EMBEDDING_*, COCOINDEX_DATABASE_URL,
# and METADATA_TABLE from above. Only reranking is opt-in:
RERANK_ENABLED=false
# RERANK_API_ADDRESS=http://localhost:8787
# RERANK_MODEL=bge-reranker-v2-m3
# RERANK_TOP_N=0

# --- Optional ---
OPENAI_API_KEY=
