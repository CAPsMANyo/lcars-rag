# Copy this file to .env and replace all placeholder values before running.

# --- Database credentials (used by both the app and docker-compose) ---
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=your-postgres-db

# Full connection URL used by the app. When using the bundled docker-compose,
# this should match the POSTGRES_* values above.
COCOINDEX_DATABASE_URL=postgresql://your-postgres-user:your-postgres-password@localhost:5432/your-postgres-db

# --- Qdrant (comment out or leave blank to use pgvector instead) ---
QDRANT_URL=http://localhost:6334
QDRANT_API_KEY=your-qdrant-api-key
# Collection name used by the embedded MCP server when searching Qdrant.
# Must match the collection cocoindex writes to.
QDRANT_COLLECTION=cocoindex

# --- Embedding ---
EMBEDDING_API_ADDRESS=http://localhost:11434/v1
EMBEDDING_MODEL=hf.co/jinaai/jina-code-embeddings-1.5b-GGUF:BF16
EMBEDDING_DIMENSION=1024

# --- Data ---
BASE_DIR=./data

# --- Filtering (uses patterns.yml) ---
USE_EXCLUDE_PATTERNS=true
MAX_FILE_SIZE=100000  # bytes, files larger than this are excluded (0 = no limit)

# --- Git (required only for HTTPS repositories) ---
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- CocoIndex ---
COCOINDEX_SOURCE_MAX_INFLIGHT_ROWS=25

# --- Source metadata ---
METADATA_TABLE=source_metadata

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Live update refresh interval (seconds) for cocoindex update -L ---
REFRESH_INTERVAL=30

# --- MCP Server (lcars-mcp-server, mounted at /mcp/http and /mcp/sse) ---
# The MCP server reuses QDRANT_*, EMBEDDING_*, COCOINDEX_DATABASE_URL, and
# METADATA_TABLE from above. Only reranking is opt-in:
RERANK_ENABLED=false
# RERANK_API_ADDRESS=http://localhost:8787
# RERANK_MODEL=bge-reranker-v2-m3
# RERANK_TOP_N=0
# Override only if the dashboard can't reach itself at 127.0.0.1:$LCARS_DASHBOARD_PORT/mcp/http/
# LCARS_MCP_INTERNAL_URL=

# --- Optional ---
OPENAI_API_KEY=
